{
  "name": "togglific",
  "version": "0.16.0",
  "description": "Do you find web animations distracting? Togglific provides a distraction-free web experience!",
  "main": "index.js",
  "scripts": {
    "start": "npm-run-all --parallel build-watch sass-watch server",
    "build-watch": "webpack --mode development --watch",
    "server": "browser-sync start reload --reloadDelay 2000 --server './brochure' --files='./brochure/**/*.*'",
    "sass": "sass --style compressed ./brochure/css/sass/brochure.scss ./brochure/css/brochure.css",
    "sass-watch": "sass --style compressed --watch ./brochure/css/sass/brochure.scss ./brochure/css/brochure.css",
    "autoprefixer": "postcss --watch ./brochure/css/brochure.css --use autoprefixer 'last 2 versions' -o ./brochure/css/brochure.css",
    "build": "npm run build-webpack && npm run bookmarklet-build && npm run stand-alone-build && npm run browser-extension-build && npm run copy-to-npm && npm run copy-to-brochure && npm run copy-to-test",
    "build-webpack": "webpack --mode production",
    "bookmarklet-build": "npm run bookmarklet-clean && npm run bookmarklet-replace && npm run bookmarklet-copy",
    "bookmarklet-clean": "rm -rf dist/bookmarklet && mkdir dist/bookmarklet",
    "bookmarklet-replace": "replace '(^.*)' 'javascript:$1void(0);' src/bundles/bookmarklet/bundle.js",
    "bookmarklet-copy": "cp src/bundles/bookmarklet/bundle.js dist/bookmarklet/togglific.js",
    "bookmarklet-demo": "uglifyjs src/bundles/bookmarklet/bundle-demo.js --quotes=3 -o src/bundles/bookmarklet/bundle-demo.js && replace '\"' '&quot;' src/bundles/bookmarklet/bundle-demo.js",
    "stand-alone-build": "npm run stand-alone-clean && npm run stand-alone-copy",
    "stand-alone-clean": "rm -rf dist/stand-alone && mkdir dist/stand-alone",
    "stand-alone-copy": "cp src/bundles/stand-alone/bundle.js dist/stand-alone/togglific.js",
    "browser-extension-build": "npm run browser-extension-clean && npm run browser-extension-copy && npm run browser-extension-zip",
    "browser-extension-clean": "rm -rf dist/browser-extension && mkdir dist/browser-extension",
    "browser-extension-copy": "cp src/bundles/browser-extension/bundle.js dist/browser-extension/togglific.js && cp src/browser-extension/background.js dist/browser-extension/ && cp src/browser-extension/manifest.json dist/browser-extension/ && cp -r src/browser-extension/icons dist/browser-extension/",
    "browser-extension-zip": "cd dist/browser-extension/ && bestzip togglific.zip *",
    "copy-to-brochure": "cp ./dist/bookmarklet/togglific.js ./brochure/javascript/togglific.js",
    "copy-to-npm": "cp ./.gitignore ./dist/npm-package && cp ./LICENSE.txt ./dist/npm-package && cp ./package.json ./dist/npm-package  && cp ./README.md ./dist/npm-package",
    "copy-to-test": "cp src/bundles/stand-alone/bundle.js test/demo/javascript/togglific.js",
    "release": "npm version patch && cp ./package.json ./dist/npm-package",
    "precommit": "npm run build && npm test && echo '🐮 Moo (Now run `git add . && git commit --no-verify -m \"informative message\"` to push the build you just made. 👆)' | cowsay",
    "test": "karma start",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d brochure"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/svinkle/togglific.git"
  },
  "keywords": [
    "animation",
    "toggle",
    "switch",
    "toggle off",
    "accessibility",
    "a11y"
  ],
  "author": "Scott Vinkle",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/svinkle/togglific/issues"
  },
  "homepage": "https://togglific.io/",
  "overrides": {
    "minimatch": "^3.1.5"
  },
  "devDependencies": {
    "@babel/core": "^7.2.2",
    "@babel/polyfill": "^7.0.0",
    "@babel/preset-env": "^7.2.0",
    "@babel/runtime": "^7.2.0",
    "autoprefixer": "^10.4.0",
    "babel-loader": "^9.0.0",
    "bestzip": "^2.1.2",
    "browser-sync": "^3.0.4",
    "cowsay": "^1.3.1",
    "gh-pages": "^6.0.0",
    "husky": "^9.0.0",
    "jasmine": "^5.0.0",
    "jasmine-core": "^5.0.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "karma-webpack": "^5.0.1",
    "npm-run-all": "^4.1.5",
    "postcss-cli": "^11.0.0",
    "replace": "^1.0.0",
    "sass": "^1.70.0",
    "terser": "^5.49.0",
    "uglify-js": "^3.4.9",
    "webpack": "^5.108.0",
    "webpack-cli": "^5.0.0"
  }
}
